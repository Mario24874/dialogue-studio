# ===========================================
# ITALIANTO DIALOGUE STUDIO - Variables de entorno
# Copia este archivo como .env.local y completa los valores
# ===========================================

# --- CLERK (autenticación) ---
# Obtener en: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/subscribe
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/subscribe

# --- SUPABASE (base de datos) ---
# Obtener en: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- STRIPE (pagos) ---
# Obtener en: https://dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# ID del precio mensual en Stripe (crear en Dashboard > Products)
STRIPE_PRICE_ID=price_...
# URL base de la app (desarrollo: http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- ANTHROPIC (traducción al italiano) ---
# Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- ELEVENLABS (generación de audio) ---
# Obtener en: https://elevenlabs.io
ELEVENLABS_API_KEY=...

# TRADUCCIÓN: mock = sin API de Claude (para testing) | live = Claude real (producción)
TRANSLATION_MODE=mock
